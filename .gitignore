# Example build artifacts (mmk writes everything under target/)
examples/*/target/

# Compiler scratch emitted next to inputs during ad-hoc runs
/main.bs
cmd/bosc/main.bs

# Editor / session scratch
*~
\#*\#
.\#*
claude.txt
codex.txt

# Saved web pages (docs scraped for reference, not part of the repo)
*.html
