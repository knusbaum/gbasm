/bosc
/bas
/bld
/bdoc
/bplayd
/bplay-runner

# Per-subproject build binaries + test-harness intermediates
cmd/bosc/bosc
cmd/bosc/bas
cmd/bosc/bld
cmd/bas/bas
cmd/bas/bld
cmd/bosc/*.bo
cmd/bosc/*.importcfg
cmd/bosc/builtin.bs
cmd/bosc/io.bs
cmd/bosc/fmt.bs
cmd/bosc/errors.bs
cmd/bosc/geom.bs
