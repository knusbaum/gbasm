package main

// Exercises the typedesc / typedesc_cache / iface_desc directives:
// assembles a structured typedesc (size_bytes=8, one method), its paired
// cache slot, and an iface_desc, then reads the typedesc's size_bytes
// (offset 16) and method_count (offset 32) back at runtime and prints them
// as ASCII digits "81\n". Validates the structured record layout and that
// field offsets read back correctly. The fn_ptr reloc targets Foo.bar,
// defined below as a stub so the link resolves.

typedesc __typedesc_Foo {
	name "Foo"
	size 8
	cache_ref __typedesc_cache_Foo
	method bar ()->i64 111 222 1 main.Foo.bar
}
typedesc_cache __typedesc_cache_Foo

iface_desc __iface_desc_Barer {
	name "Barer"
	method bar ()->i64 111 222 0
}

function Foo.bar
	mov rax 0
	ret

function main
	lea rbx __typedesc_Foo
	// size_bytes at [td+16] -> '8'
	mov rax qword[rbx+16]
	add rax 48
	mov byte[rsp-3] al
	// method_count at [td+32] -> '1'
	mov rax qword[rbx+32]
	add rax 48
	mov byte[rsp-2] al
	mov byte[rsp-1] 10
	lea rsi [rsp-3]
	mov rdx 3
	mov rax 1
	mov rdi 1
	syscall

	xor rax rax
	ret
