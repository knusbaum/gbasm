package main

var newline string "\n\0"

// Tests all four valid scale values (1, 2, 4, 8) in base+index*scale addressing.
// All four expressions are constructed to compute the same address (rsp+8),
// so they all read the same sentinel value.
function main
	sub rsp 32

	mov rax 99
	mov [rsp+8] rax

	// scale=1, index=8:  rsp + 8*1 = rsp+8
	mov rcx 8
	mov rdi [rsp+rcx*1]
	call puti
	lea rdi newline
	call puts

	// scale=2, index=4:  rsp + 4*2 = rsp+8
	mov rcx 4
	mov rdi [rsp+rcx*2]
	call puti
	lea rdi newline
	call puts

	// scale=4, index=2:  rsp + 2*4 = rsp+8
	mov rcx 2
	mov rdi [rsp+rcx*4]
	call puti
	lea rdi newline
	call puts

	// scale=8, index=1:  rsp + 1*8 = rsp+8
	mov rcx 1
	mov rdi [rsp+rcx*8]
	call puti
	lea rdi newline
	call puts

	add rsp 32
	xor rax rax
	ret
