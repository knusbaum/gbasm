package main

// A slice parameter is borrowed. Sub-slicing it preserves the borrow —
// `s[1:]` aliases the same backing as `s`, so returning it routes a
// caller's storage past its lifetime just like `return s` would.
//
// Boson rejects bare borrowed-slice returns today; SliceOp-of-borrowed
// must reach the same conclusion.

fn tail(s byte[]) byte[] {
	return s[1:]
}

fn main() {}
