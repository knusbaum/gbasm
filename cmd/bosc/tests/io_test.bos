package main

import "string"

// #define O_RDONLY	00000000
// #define O_WRONLY	00000001
// #define O_RDWR		00000002
// #define O_CREAT		00000100

fn main() i64 {
	var fd i64
	fd = string.open("./tests/io_test.bos", 0, 0)
	if (fd < 0) {
		string.puts("Failed to open io_test.bos: ")
		string.puti(fd)
		string.puts("\n")
		return 1
	}

	// create a buffer to hold file contents
	var buf byte[100]

	// create a slice to refer to the buffer.
	var bs byte[]
	bs = buf[:]
	
	var n i64
	n = string.read(fd, bs)
	// extra security. This should not be necessary
	// with 
	bs[10] = 'a'

	// write stdout
	n = string.write(1, bs[:n])
	return 0
}
