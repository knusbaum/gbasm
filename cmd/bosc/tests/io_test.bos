package main

import "string"
import "_io_sys"

// #define O_RDONLY	00000000
// #define O_WRONLY	00000001
// #define O_RDWR		00000002
// #define O_CREAT		00000100

fn main() i64 {
	var fd i64
	fd = _io_sys.open("./tests/io_test.bos", 0, 0)
	if (fd < 0) {
		string.puts("Failed to open io_test.bos: ")
		string.puti(fd)
		string.puts("\n")
		return 1
	}

	// create a buffer to hold file contents
	var buf byte[100]

	// create a slice to refer to the buffer.
	var bs mut byte[]
	bs = buf[:]

	var n i64
	n = _io_sys.read(fd, bs)
	// extra security. This should not be necessary
	// with
	bs[10] = 'a'

	// write stdout
	n = _io_sys.write(1, bs[:n])
	return 0
}
