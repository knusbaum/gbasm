package main

import "string.bo"

// #define O_RDONLY	00000000
// #define O_WRONLY	00000001
// #define O_RDWR		00000002
// #define O_CREAT		00000100

fn main() num {
	var fd num
	fd = open("./tests/io_test.bos", 0, 0)
	if (fd < 0) {
		puts("Failed to open io_test.bos: ")
		puti(fd)
		puts("\n")
		return 1
	}

	// create a buffer to hold file contents
	var buf byte[100]

	// create a slice to refer to the buffer.
	var bs byte[]
	bs = buf[:]
	
	var n num
	n = read(fd, bs)
	// extra security. This should not be necessary
	// with 
	bs[10] = 'a'

	// write stdout
	n = write(1, bs[:n])
	return 0
}
