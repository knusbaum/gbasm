package main

import "string.bo"

fn main() {
	var x u16
	x = 100

	// add/sub
	x = x + 50
	if (x == 150) { puts("add ok\n") } else { puts("add fail\n") }

	x = x - 75
	if (x == 75) { puts("sub ok\n") } else { puts("sub fail\n") }

	// mul/div
	x = x * 4
	if (x == 300) { puts("mul ok\n") } else { puts("mul fail\n") }

	x = x / 3
	if (x == 100) { puts("div ok\n") } else { puts("div fail\n") }

	// unsigned overflow: UINT16_MAX + 1 = 0
	var mx u16
	mx = 65535
	mx = mx + 1
	if (mx == 0) { puts("wrap ok\n") } else { puts("wrap fail\n") }

	// unsigned underflow: 0 - 1 = 65535
	var z u16
	z = 0
	z = z - 1
	if (z == 65535) { puts("underflow ok\n") } else { puts("underflow fail\n") }
}
