package main

// A concrete type whose `bytes` returns a borrow of its receiver (inferred
// ReturnAliases non-empty), coerced to an interface that requires `bytes`
// but declares NO `from(...)` contract for it. Rejected by the ⊆ conformance
// rule: the impl's inferred borrow {receiver} is not ⊆ Byter's declared ∅.
// The fix is to declare `from(self)` on Byter (then it conforms). Concrete
// `h.bytes()` still works; only this uncovered coercion is forbidden.
type Holder struct { buf byte[] } {
	bytes(h *Holder) byte[] { return h.buf }
}

interface Byter {
	bytes(s *self) byte[]
}

fn coerce(h *Holder) Byter {
	return h
}

fn main() {}
