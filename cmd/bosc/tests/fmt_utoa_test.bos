package main
import "fmt"
import "string"

// Layer 1: utoa renders unsigned decimals and returns a sub-slice of the
// caller buffer. Covers zero, a mid value, a large value above the i64
// range, the truncation contract, and n_udigits.
fn show(n u64) i64 {
	var buf byte[32]
	const s byte[] = fmt.utoa(buf[:], n)
	string.puts(s)
	string.puts(" (")
	string.puti(fmt.n_udigits(n))
	string.puts(")\n")
	return 0
}

fn main() i64 {
	show(u64(0))
	show(u64(12345))
	show(u64(18446744073709551615))   // max u64
	var small byte[2]
	const s1 byte[] = fmt.utoa(small[:], u64(12345))
	string.puts(s1)
	string.puts(" trunc=")
	string.puti(len(s1))
	string.putc(10)
	return 0
}
