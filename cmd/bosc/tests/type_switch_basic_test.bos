package main
import "string"

fn describe(x any) {
	switch (v x.(type)) {
		case i64 { string.puti(v); string.putc(10) }
		case *mut i64 { string.puti(*v); string.putc(10) }
		default { string.puti(999); string.putc(10) }
	}
}

fn main() i64 {
	var m i64 := 42
	var bb byte := 7
	describe(m)
	describe(&m)
	describe(bb)
	return 0
}
