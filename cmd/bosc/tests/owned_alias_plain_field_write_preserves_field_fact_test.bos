package main

type leaf struct {
	val i64
}

type box struct {
	val i64
	child owned *?owned mut leaf
}

fn destroy(b owned *owned mut box) {
	var alias *mut box := b
	var child owned *?owned mut leaf := b.child
	alias.val = 10
	free(b)
	if (child) {
		free(child)
	}
}

fn main() {
	b owned *owned mut box := new(box{val: 1, child: nil})
	destroy(b)
}
