package main
import "fmt"
import "io"

// Layer 5: %v dispatches to stringer. This stringer returns a static .rodata
// slice (borrows nothing), which satisfies stringer's `from(self)` contract by
// ⊆ (∅ ⊆ {self}); the concrete type coerces to `any` (the vararg shape) and
// dispatches through render_v's `a.(stringer)` assertion. The borrowed-field
// variant — `return self.buf` — is also valid now and pinned by
// fmt_stringer_borrowed_field_test.
type word struct { tag i64 } {
	string(_ *word) byte[] { return "hello-stringer" }
}

fn main() i64 {
	var w word := word{tag: 1}
	fmt.print("v=%v\n", &w)
	return 0
}
