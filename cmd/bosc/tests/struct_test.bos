package main

import "string"

struct point {
	x i64
	y i64
	z i64
}

fn structfn(var p point) {
	string.puti(p.x)
	string.puts("\n")

	string.puti(p.y)
	string.puts("\n")
	
	string.puti(p.z)
	string.puts("\n")

	p.x = p.x + 100
	p.y = p.y + 100
	p.z = p.z + 100
}

fn structPtrFn(p *mut point) {
 	string.puti(p.x)
 	string.puts("\n")

	string.puti(p.y)
	string.puts("\n")
	
	string.puti(p.z)
	string.puts("\n")

	p.x = p.x + 100
	p.y = p.y + 100
	p.z = p.z + 100
}

fn structPtrCopyFn(p *point) {
	var p2 point

	p2 = *p

	p2.x = p2.x + 100
	p2.y = p2.y + 100
	p2.z = p2.z + 100
	
 	string.puti(p2.x)
 	string.puts("\n")

	string.puti(p2.y)
	string.puts("\n")
	
	string.puti(p2.z)
	string.puts("\n")	
}

fn main() i64 {
	var p point

	p = point{
		x: 10,
		y: 20,
		z: 30
	}
	
	// p.x = 10
	// p.y = 20
	// p.z = 30
	
	structfn(p)
	
	string.puti(p.x)
	string.puts("\n")

	string.puti(p.y)
	string.puts("\n")
	
	string.puti(p.z)
	string.puts("\n")

	p.x = 100
	p.y = 200
	p.z = 300
	structPtrFn(&p)

	string.puti(p.x)
	string.puts("\n")

	string.puti(p.y)
	string.puts("\n")
	
	string.puti(p.z)
	string.puts("\n")


	structPtrCopyFn(&p)

	string.puti(p.x)
	string.puts("\n")

	string.puti(p.y)
	string.puts("\n")
	
	string.puti(p.z)
	string.puts("\n")
	
}
