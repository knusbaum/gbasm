package main

import "string"

fn putin(i i64) {
   string.puti(i)
   string.puts("\n")
}

fn retten() i64 {
   return 10
}

fn retx(x i64) i64 {
   return x
}

fn threearg(x i64, y i64, z i64) i64 {
   return x + y + z
}

fn main() {
   var x i64
   x = retten()
   putin(x)
   // 10

   putin(retten())
   // 10

   putin(retx(10))
   // 10

   putin(retx(10 * 10))
   // 100

   putin(threearg(10 * 10, 20 * 20, 30 * 30))
   // 1400
}
