package main

import "string.bo"

fn main() {
	var x i64
	x = 100

	// add/sub
	x = x + 50
	if (x == 150) { puts("add ok\n") } else { puts("add fail\n") }

	x = x - 75
	if (x == 75) { puts("sub ok\n") } else { puts("sub fail\n") }

	// mul/div
	x = x * 4
	if (x == 300) { puts("mul ok\n") } else { puts("mul fail\n") }

	x = x / 3
	if (x == 100) { puts("div ok\n") } else { puts("div fail\n") }

	// signed comparisons: neg = -1
	var neg i64
	neg = 0
	neg = neg - 1
	if (neg < 0) { puts("neg lt ok\n") } else { puts("neg lt fail\n") }
	if (neg > 0) { puts("neg gt fail\n") } else { puts("neg gt ok\n") }

	// negative division
	var a i64
	a = 0
	a = a - 10
	a = a / 2
	var expected i64
	expected = 0
	expected = expected - 5
	if (a == expected) { puts("neg div ok\n") } else { puts("neg div fail\n") }
}
