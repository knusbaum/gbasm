package main

import "string"

// Statement boundaries — newlines after statement-ending tokens act
// as terminators (lexer auto-inserts ';'). Without that, a line
// starting with '*' or '-' would be eaten as a binary operator
// applied to the previous statement.

fn main() {
	var x i64 = 7
	var px *mut i64 = &x

	// `(close-paren)' ends the first statement; `*px` on the next
	// line is a Deref, not a multiplication of `string.puti(*px)` by
	// `px`. Before auto-insertion, this combination tripped the parser
	// into producing Mul(string.puti(*px), px), which then panicked
	// in compileLval with "(LVAL) FALLTHROUGH: Op2{n_mul, ...}".
	string.puti(*px)
	string.putc('\n')
	*px = 99
	string.puti(*px)
	string.putc('\n')

	// Similarly: `-1` on a new line is a unary minus introducing
	// a fresh assignment, not subtraction from the previous statement.
	var y i64 = 5
	-1
	string.puti(y)
	string.putc('\n')

	// Continuation lines work because the trailing operator isn't
	// a statement-ender. Splitting an expression across newlines is
	// silently fine.
	var z i64 = 1 +
		2 +
		3
	string.puti(z)
	string.putc('\n')
}
