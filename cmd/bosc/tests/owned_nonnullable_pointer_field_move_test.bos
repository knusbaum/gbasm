package main

import "fmt"

// A non-null owned pointer field can be moved out, cleaned up, and the
// aggregate then disposed — the partial-disposal / typestate feature
// (PROPOSAL_owned_field_move.md). Previously this was rejected with
// "Cannot move non-null pointer field next; use *?T …".
type box struct {
	next owned *mut i64
}

fn main() {
	var p owned *mut i64 = alloc(i64)
	*p = 42
	var b owned box = box{next: p}
	var next owned *mut i64 = b.next // move the non-null owned field out
	fmt.print("next=%d\n", *next)
	free(next) // clean up the field's resource
	dispose(b) // aggregate now consistent (only owned field consumed)
	fmt.print("destroyed\n")
}
