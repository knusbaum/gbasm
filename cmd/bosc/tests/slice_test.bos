fn slicetest(bs byte[]) {
	var i i64
	i = 0
	i = i + 5

	bs[5] = 10
	bs[6] = 20

	puti(lenb(bs))
	puts("\n")
	
	bs = bs[i:]
	puti(lenb(bs))
	puts("\n")

	putb(bs[0])
	puts("\n")

	bs = bs[:i]
	puti(lenb(bs))
	puts("\n")

	i = 1
	bs = bs[i:i+1]
	puti(lenb(bs))
	puts("\n")
	
	putb(bs[0])
	puts("\n")
}
