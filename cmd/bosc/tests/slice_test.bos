package main

import "string.bo"

fn main() {
	var a byte[10]
	a[0] = 1
	a[1] = 2
	a[2] = 3
	a[3] = 4
	var b byte[]
	b = a[:]
	putb(b[0])
	puts("\n")
	putb(b[1])
	puts("\n")

	b = a[:2]
	putb(b[0])
	puts("\n")

	b = a[2:]
	putb(b[0])
	puts("\n")

	var arr byte[50]
	slicetest(arr[:])

	var i i64
	var bb byte
	for(i = 0; i < 50; i = i + 1) {
		bb = arr[i]
	}

	var bs byte[]
	bs = arr[:]
	for(i = 0; i < 50; i = i + 1) {
		bb = bs[i]
	}

	// bs = arr[10:20]
	// for(i = 0; i < 50; i = i + 1) {
	// 	bb = bs[i]
	// }
	
	// boundstest()
}

