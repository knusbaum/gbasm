package main

// VarDecl struct-literal initializer with a borrowed slice tucked one
// level down in a nested struct literal, then the binding is returned
// by value. Mirrors the assign-to-global case but at the var-init site,
// which records field facts through its own loop (separate from
// Assignment's struct-literal branch).

type Inner struct {
	buf byte[]
}
type Outer struct {
	inner Inner
}

fn bad(s byte[]) Outer {
	var b Outer = Outer{inner: Inner{buf: s}}
	return b
}

fn main() {}
