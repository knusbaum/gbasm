package main
import "string"

type foo struct { x i64 }

fn main() i64 {
	var f foo = foo{x: 3}
	var a any = &f
	var p *mut foo, var ok bool = a.(*mut foo)
	if (ok) { string.puti(1) } else { string.puti(0) }
	string.putc(10)
	var q *foo, var ok2 bool = a.(*foo)
	if (ok2) { string.puti(1) } else { string.puti(0) }
	string.putc(10)
	return 0
}
