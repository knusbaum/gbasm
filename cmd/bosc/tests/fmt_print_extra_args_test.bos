package main
import "fmt"
import "io"
import "string"

// Layer 5: more args than directives — trailing args are appended %v-style,
// space-separated, and a surplus error is latched. One surplus arg is a
// stringer (passed by reference) so the %v append renders real text rather
// than the placeholder, exercising the dispatch path on the surplus tail.
type word struct { s byte[] } {
	string(w *word) byte[] { return w.s }
}

fn main() i64 {
	var w word = word{s: "tail"}
	const n, var err = fmt.print("first=%d", 1, 2, &w)
	string.putc(10)
	if (err != io.io_err.OK) {
		string.puts("surplus latched\n")
	} else {
		string.puts("NO ERROR (unexpected)\n")
	}
	return 0
}
