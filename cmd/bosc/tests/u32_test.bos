package main

import "string"

fn main() {
	var x u32
	x = 1000

	// add/sub
	x = x + 500
	if (x == 1500) { string.puts("add ok\n") } else { string.puts("add fail\n") }

	x = x - 750
	if (x == 750) { string.puts("sub ok\n") } else { string.puts("sub fail\n") }

	// mul/div
	x = x * 4
	if (x == 3000) { string.puts("mul ok\n") } else { string.puts("mul fail\n") }

	x = x / 3
	if (x == 1000) { string.puts("div ok\n") } else { string.puts("div fail\n") }

	// unsigned overflow wraps: UINT32_MAX + 1 = 0
	var mx u32
	mx = 4294967295
	mx = mx + 1
	if (mx == 0) { string.puts("wrap ok\n") } else { string.puts("wrap fail\n") }

	// unsigned: value 0 - 1 wraps to UINT32_MAX, which is > 0
	var z u32
	z = 0
	z = z - 1
	if (z > mx) { string.puts("underflow ok\n") } else { string.puts("underflow fail\n") }
}
