package main

// The laundering path: a borrowing-method type would be packed into `any`,
// then asserted with a.(Byter).bytes() to dispatch the borrowing method
// through a runtime-minted itab. Because the coercion TO `any` is rejected
// (option (a)), the program never reaches the assertion — the failure is
// reported at the coercion to `any`, not at the .(Byter) site. This
// confirms the hole is closed at the single static entry point.
type Holder struct { buf byte[] } {
	bytes(h *Holder) byte[] { return h.buf }
}

interface Byter {
	bytes(s *self) byte[]
}

fn launder(h *Holder) byte[] {
	var a any = h
	var bt Byter, var ok bool = a.(Byter)
	if (ok) {
		return bt.bytes()
	}
	return h.buf
}

fn main() {}
