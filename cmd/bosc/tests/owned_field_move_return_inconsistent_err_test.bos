package main

type pair struct {
	a owned *mut i64
	b owned *mut i64
}

fn build() owned *owned mut pair {
	var p owned *owned mut pair := new(pair{a: alloc(i64), b: alloc(i64)})
	var a owned *mut i64 := p.a
	free(a)
	return p
}

fn main() {
	var p owned *owned mut pair := build()
	free(p.a)
	free(p.b)
	free(p)
}
