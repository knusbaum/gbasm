package main

import "string"

fn dumpbs(bs byte[]) {
	var i i64
	for (i = 0; i < string.lenb(bs); i = i + 1) {
		string.putb(bs[i])
		string.putc(' ')
	}
	string.putc('\n')
}

fn main() {
	var a byte[20]

	var i byte
	var ten byte
	ten = 10
	for(i = 0; i < ten; i = i + 1) {
		a[i] = i
	}
	dumpbs(a[:10])

	var bs byte[]
	bs = a[10:]
	for(i = 0; i < ten; i = i + 1) {
		bs[i] = i+10
	}
	dumpbs(bs[:10])

	for(i = 0; i < ten; i = i + 1) {
		a[i] = bs[i]
	}

	dumpbs(a[:10])
}
