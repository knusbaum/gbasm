package main
import "string"

// m4: one source value asserted to two different interfaces in sequence. Both
// succeed and dispatch through their own method, exercising two distinct itabs
// chained on the single typedesc cache for `worker`.
type worker i64 {
	greet(w *self) byte[] {
		return "hi"
	}
	farewell(w *self) byte[] {
		return "bye"
	}
}

interface speaker {
	greet(s *self) byte[]
}

interface closer {
	farewell(c *self) byte[]
}

fn main() i64 {
	var w worker := 3
	a any := &w

	s ?speaker := a.(speaker)
	if (s != nil) { string.puts(s.greet()) } else { string.puts("no1") }
	string.putc(10)

	c ?closer := a.(closer)
	if (c != nil) { string.puts(c.farewell()) } else { string.puts("no2") }
	string.putc(10)

	// Re-assert the first interface: now a cache hit on the same typedesc cache.
	s2 ?speaker := a.(speaker)
	if (s2 != nil) { string.puts(s2.greet()) } else { string.puts("no3") }
	string.putc(10)
	return 0
}
