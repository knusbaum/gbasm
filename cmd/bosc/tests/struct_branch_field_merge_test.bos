package main

import "string"

type Foo struct {
	x  i64
	xp *?i64
}

var gx i64
var gy i64

fn mkfoo(var set i64) Foo {
	var s Foo := Foo{x: 10, xp: nil}
	if (set) {
		s.xp = &gx
	} else {
		s.xp = &gy
	}
	return s
}

fn main() {
	a Foo := mkfoo(0)
	b Foo := mkfoo(1)
	string.puti(a.x)
	string.puts("\n")
	string.puti(b.x)
	string.puts("\n")
}
