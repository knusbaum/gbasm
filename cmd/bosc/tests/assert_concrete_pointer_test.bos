package main
import "string"

type foo struct { x i64 }

fn main() i64 {
	var f foo := foo{x: 55}
	a any := &f
	p *mut foo, ok bool := a.(*mut foo)
	if (ok) { string.puti(p.x) } else { string.puti(-1) }
	string.putc(10)
	q *mut i64, ok2 bool := a.(*mut i64)
	if (ok2) { string.puti(1) } else { string.puti(0) }
	string.putc(10)
	return 0
}
