package main

import "string"

// A recursive function returning a parameter alias. The cycle fixpoint
// converges on the precise per-slot union of the base and recursive
// cases — here {param 0} — and the caller-side propagation still permits
// correct use: drop_spaces walks to the first non-space, returning a
// sub-slice of s.
fn drop_spaces(s byte[]) byte[] {
	if (len(s) == 0) {
		return s
	}
	if (s[0] == 32) {
		return drop_spaces(s[1:len(s)])
	}
	return s
}

fn main() i64 {
	var src byte[] := "   hi"
	var r byte[] := drop_spaces(src)
	string.puts(r)
	string.puts("\n")
	return 0
}
