package main

import "io"
import "string"

// Cross-package type alias test. The `io` package defines `type FD i64`
// with read, write, and close methods. This test exercises:
//   - declaring a local of type io.FD via io.open (multi-value return)
//   - casting an integer to io.FD with the qualified form io.FD(n)
//   - calling methods on an owned io.FD (write, close)
//   - the owned obligation is satisfied by close
fn main() i64 {
    // Write to /dev/null through a FD — result discarded, proves type works.
    var null owned io.FD, const openerr i64 = io.open("/dev/null", 1, 0)
    null.write("this goes nowhere\n")
    null.close()

    // Use a raw integer cast to build a FD, write through it, close it.
    var fd owned io.FD = owned(io.FD(1))
    fd.write("cross pkg type alias\n")
    fd.close()

    return 0
}
