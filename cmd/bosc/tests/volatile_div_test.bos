package main

import "string"

fn main() {
	var x i64
	x = 42

	var y i64
	y = 6

	px *mut i64 := &x

	py *mut i64 := &y

	// Volatile first operand.
	x = x / 7
	string.puti(*px)
	string.puts("\n")

	// Volatile second operand.
	y = 100 / y
	string.puti(*py)
	string.puts("\n")

	// Both volatile.
	x = x * y
	string.puti(*px)
	string.puts("\n")
}
