package main
import "string"

// T has a value-receiver method f and a pointer-receiver method g.
type tt i64 {
	f(self tt) byte[] {
		return "f"
	}
	g(self *tt) byte[] {
		return "g"
	}
}

interface Vi {
	f(self tt) byte[]
}
interface Pi {
	g(self *tt) byte[]
}

fn report(label byte[], ok bool) i64 {
	string.puts(label)
	if (ok) { string.puts("Y") } else { string.puts("N") }
	string.putc(10)
	return 0
}

fn main() i64 {
	var x tt := 5
	// value-shape any: must pass .(Vi), fail .(Pi)
	av any := x
	v1 ?Vi := av.(Vi)
	report("av.Vi=", v1 != nil)
	p1 ?Pi := av.(Pi)
	report("av.Pi=", p1 != nil)
	// pointer-shape any: must pass .(Pi), fail .(Vi)
	ap any := &x
	v2 ?Vi := ap.(Vi)
	report("ap.Vi=", v2 != nil)
	p2 ?Pi := ap.(Pi)
	report("ap.Pi=", p2 != nil)
	return 0
}
