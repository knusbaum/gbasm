package main
import "string"
import "geom"
import "ifaces"

// geom.Point (concrete, with describe method) declared in package geom;
// ifaces.Stringer (interface) declared in package ifaces. Assert across
// both .bo boundaries.
fn main() i64 {
	var p geom.Point = geom.make(1, 2)
	var a any = &p
	var s ?ifaces.Stringer = a.(ifaces.Stringer)
	if (s != nil) {
		string.puts(s.describe())
	} else {
		string.puts("no")
	}
	string.putc(10)
	return 0
}
