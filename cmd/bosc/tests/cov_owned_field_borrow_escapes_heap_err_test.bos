package main

import "fmt"

// #10-class headline: a borrow of an owned field, copied into heap memory via
// new(), loses its alias to the source — dispose can't reach it.
type box    struct { x owned i64 }
type holder struct { p *i64 }

fn main() {
	s owned box := box{x: 10}
	h owned *mut holder := new(holder{p: &s.x})
	dispose(s)
	fmt.print("%d\n", *h.p)
	free(h)
}
