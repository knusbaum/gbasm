package main

// A field consumed on a `continue` path but live on the fall-through reaches
// the loop back-edge in two different states; the next iteration could
// re-move the already-consumed field (a double-free). Must be rejected.
type foo struct {
	a owned *mut i64
}

fn main(args byte[][]) {
	var f owned foo := foo{a: alloc(i64)}
	var i i64 := 0
	for (i = 0; i < 3; i = i + 1) {
		if (len(args) > 1) {
			free(f.a)
			continue
		}
	}
	dispose(f)
}
