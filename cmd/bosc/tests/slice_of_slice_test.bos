package main

import "string"

// Helper to make a byte[][]. In real code this would come from
// an assembly-written runtime function (e.g. argv conversion).
// For now, we accept a byte[][] from outside and just exercise indexing.
fn show(ss byte[][], i i64) {
	var s byte[] = ss[i]
	string.puts(s)
	string.putc('\n')
}

fn main() {
	// Construct a byte[][] by hand on the stack. We have:
	//   storage[0..48): three 16-byte slice headers
	//   ss: the outer slice header pointing at storage with len=3
	var storage byte[48]
	var ss byte[][]

	// Three short string literals.
	var s0 byte[] = "alpha"
	var s1 byte[] = "beta"
	var s2 byte[] = "gamma"

	// We don't yet have a clean way to write s0 into storage[0..16] from
	// Boson source (no struct-cast / no slice assignment to byte[] regions
	// at byte granularity). Punt — this test just exercises type-level
	// support: declaring, calling functions with byte[][] parameter, etc.

	// Index into ss (will trap since len=0, but type checks).
	// Commented out for the actual test:
	// show(ss, 0)

	// Just confirm we got here.
	string.puts("byte[][] declared and parameter passed OK\n")

	// Silence unused-var warnings (none currently — but use them).
	if (string.lenb(s0) > 0) {
		if (string.lenb(s1) > 0) {
			if (string.lenb(s2) > 0) {
				if (string.lenb(ss) == 0) {
					storage[0] = 0
				}
			}
		}
	}
}
