package main

import "string"

// Helper that takes a byte[][] parameter. Declaring it exercises parameter-
// type parsing and codegen for byte[][]. We never call it here — this test
// is purely a type-level exercise (declaration, sizing, fn-param type).
fn show(ss byte[][], i i64) {
	s byte[] := ss[i]
	string.puts(s)
	string.putc('\n')
}

fn main() {
	// Declare a byte[][] local — pure type-level exercise.
	ss byte[][]

	string.puts("byte[][] declared and parameter passed OK\n")
}
