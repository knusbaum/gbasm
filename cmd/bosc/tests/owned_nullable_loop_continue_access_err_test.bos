package main

type node struct {
	next owned *?owned mut node
}

fn destroy(l owned *?owned mut node) {
	var curr owned *?owned mut node = l
	var next owned *?owned mut node
	for(; curr != nil; curr = next) {
		next = curr.next
		free(curr)
		continue
	}
	dispose(curr)
}

fn main() {
	var head owned *?owned mut node = owned(alloc(node))
	var tail owned *?owned mut node = owned(alloc(node))
	var raw_tail *?mut node = tail
	raw_tail.next = nil
	var raw_head *?mut node = head
	raw_head.next = tail
	dispose(tail)
	destroy(head)
}
