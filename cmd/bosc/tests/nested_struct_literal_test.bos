package main

import "string"

type inner struct { z i64 }
type mid struct { z i64; w i64 }
type outer1 struct { x i64; in inner }
type outer2 struct { x i64; in mid }

fn main() {
	a outer1 := outer1{x: 1, in: inner{z: 2}}
	string.puti(a.x); string.putc('\n')
	string.puti(a.in.z); string.putc('\n')

	b outer2 := outer2{x: 10, in: mid{z: 20, w: 30}}
	string.puti(b.x); string.putc('\n')
	string.puti(b.in.z); string.putc('\n')
	string.puti(b.in.w); string.putc('\n')
}
