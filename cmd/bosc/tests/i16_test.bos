package main

import "string"

fn main() {
	var x i16
	x = 100

	// add/sub
	x = x + 50
	if (x == 150) { string.puts("add ok\n") } else { string.puts("add fail\n") }

	x = x - 75
	if (x == 75) { string.puts("sub ok\n") } else { string.puts("sub fail\n") }

	// mul/div
	x = x * 4
	if (x == 300) { string.puts("mul ok\n") } else { string.puts("mul fail\n") }

	x = x / 3
	if (x == 100) { string.puts("div ok\n") } else { string.puts("div fail\n") }

	// signed: negative (neg = 0 - 1 = -1)
	var neg i16
	neg = 0
	neg = neg - 1
	if (neg < 0) { string.puts("neg lt ok\n") } else { string.puts("neg lt fail\n") }

	// signed overflow: INT16_MAX + 1 = INT16_MIN (negative)
	var mx i16
	mx = 32767
	mx = mx + 1
	if (mx < 0) { string.puts("overflow ok\n") } else { string.puts("overflow fail\n") }
}
