package main

import "string"

// Array literals as initializers for local fixed-array variables.
// Element-wise stores into the bytes-allocated array. Slice
// destinations at runtime would need lifetime-stable backing storage
// that bosc can't synthesize, so they're explicitly rejected.

fn main() {
	// Scalar element type, constant-index reads.
	var nums i64[3] := [10, 20, 30]
	string.puti(nums[0])
	string.putc(' ')
	string.puti(nums[1])
	string.putc(' ')
	string.puti(nums[2])
	string.putc('\n')

	// Runtime-indexed read confirms element layout matches expected
	// stride (8 bytes per i64).
	var i i64
	for (i = 0; i < 3; i = i + 1) {
		string.puti(nums[i])
		string.putc(' ')
	}
	string.putc('\n')

	// Byte-sized element type — different scale.
	var bs byte[4] := [72, 105, 33, 10]   // 'H' 'i' '!' '\n'
	string.puts(bs[:])
}
