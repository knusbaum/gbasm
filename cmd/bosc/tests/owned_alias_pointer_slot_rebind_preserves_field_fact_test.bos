package main

type leaf struct {
	val i64
}

type box struct {
	val i64
	child owned *?owned mut leaf
}

fn destroy(b owned *owned mut box) {
	other owned *owned mut box := new(box{val: 2, child: nil})
	other_child owned *?owned mut leaf := other.child
	var alias *mut box := b
	slot *mut *mut box := &alias
	child owned *?owned mut leaf := b.child
	other_alias *mut box := other
	*slot = other_alias
	alias.val = 3
	free(b)
	free(other)
	if(child) {
		free(child)
	}
	if(other_child) {
		free(other_child)
	}
}

fn main() {
	b owned *owned mut box := new(box{val: 1, child: nil})
	destroy(b)
}
