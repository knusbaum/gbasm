package main
import "string"

// B1 regression: &args has composite type *(byte[][]). Coercing it into `any`
// previously emitted a vtable whose typedesc relocation named main.__typedesc_
// (empty base) and the linker rejected it. The base type now resolves through
// shapeBaseName ("byte"), so the coercion links and runs against real argv.
fn main(args byte[][]) i64 {
	var a any = &args
	string.puts("argv coerced ")
	string.puti(len(args))
	string.putc(10)
	return 0
}
