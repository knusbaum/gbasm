package main

// Multi-level lvalue field write: assigning a borrowed slice into a
// nested struct's field, then returning the outer struct by value.
// Previously a known gap because fieldPointers was single-level only;
// the FlowPath migration records "o.inner.buf" as a real path, so
// CheckStructFieldEscape now sees it on return.

type Inner struct {
	buf byte[]
}
type Outer struct {
	inner Inner
}

fn bad(s byte[]) Outer {
	var o Outer
	o.inner.buf = s
	return o
}

fn main() {}
