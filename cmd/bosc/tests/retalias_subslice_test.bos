package main

import "string"

// first_word returns a sub-slice of its borrowed parameter. Inferred
// return-parameter aliasing records ReturnAliases=[[0]]; the caller may
// use the view as long as the argument outlives it.
fn first_word(s byte[]) byte[] {
	var i i64 = 0
	for (; i < len(s); i = i + 1) {
		if (s[i] == 32) {
			return s[0:i]
		}
	}
	return s
}

fn main() i64 {
	var src byte[] = "hello world"
	var w byte[] = first_word(src)
	string.puts(w)
	string.puts("\n")
	return 0
}
