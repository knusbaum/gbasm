package main
import "fmt"
interface speaker { val(s *self) i64 }
type num struct { n i64 } {
	val(p *num) i64 { return p.n }
}
// Dispatch on an interface value returned from a function.
fn pick(p *num) speaker { return p }
fn main() {
	var x num := num{n: 9}
	s speaker := pick(&x)
	fmt.print("%d\n", s.val())
}
