package main

import "string.bo"

fn main() {
	var x i32
	x = 1000

	// add/sub
	x = x + 500
	if (x == 1500) { puts("add ok\n") } else { puts("add fail\n") }

	x = x - 750
	if (x == 750) { puts("sub ok\n") } else { puts("sub fail\n") }

	// mul/div
	x = x * 4
	if (x == 3000) { puts("mul ok\n") } else { puts("mul fail\n") }

	x = x / 3
	if (x == 1000) { puts("div ok\n") } else { puts("div fail\n") }

	// signed: negative
	var neg i32
	neg = 0
	neg = neg - 1
	if (neg < 0) { puts("neg lt ok\n") } else { puts("neg lt fail\n") }

	// signed overflow wraps: INT32_MAX + 1 = INT32_MIN
	var mx i32
	mx = 2147483647
	mx = mx + 1
	if (mx < 0) { puts("overflow ok\n") } else { puts("overflow fail\n") }
}
