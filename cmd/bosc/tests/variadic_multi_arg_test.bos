package main
import "string"

fn show(args ...any) {
	for (var i i64 = 0; i < len(args); i = i + 1) {
		switch (v args[i].(type)) {
			case i64 { string.puti(v) }
			case *mut i64 { string.puti(*v) }
			default { string.puti(0) }
		}
		string.putc(10)
	}
}

fn main() i64 {
	var m i64 = 100
	show(1, &m, 3)
	return 0
}
