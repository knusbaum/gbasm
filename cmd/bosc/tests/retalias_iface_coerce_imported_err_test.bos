package main

import "retalias_pkg"

interface Byter {
	bytes(s *self) byte[]
}

// A borrowing-method type defined in an IMPORTED package, coerced to an
// interface in the consumer that declares no `from(...)` for the required
// method. Rejected by the ⊆ conformance rule using the importer-attached
// ReturnAliases fact: the imported type's bytes() carries its inferred alias
// set across the .bo boundary, so the conformance check sees the borrow.
// Pins the imported-type diagnostic rendering across the package boundary.
fn coerce(h *retalias_pkg.borrowing_holder) Byter {
	return h
}

fn main() {}
