package main

import "string"
import "retalias_pkg"

// A callee in package retalias_pkg returns a sub-slice of its parameter;
// its inferred ReturnAliases travels through the .bo. The caller here uses
// the returned view correctly — the argument (a local backing the slice)
// outlives the use within this function.
fn main() i64 {
	var src byte[] = "cross package"
	var w byte[] = retalias_pkg.first_word(src)
	string.puts(w)
	string.puts("\n")
	return 0
}
