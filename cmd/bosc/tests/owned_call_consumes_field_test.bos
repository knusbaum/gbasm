package main

type leaf struct {
	val i64
}

type box struct {
	child owned *?owned mut leaf
}

fn consume_leaf(l owned *?owned mut leaf) {
	if(l) {
		free(l)
	}
}

fn destroy(b owned *owned mut box) {
	consume_leaf(b.child)
	free(b)
}

fn main() {
	b owned *owned mut box := new(box{child: nil})
	destroy(b)
}
