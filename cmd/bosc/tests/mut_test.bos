package main

import "string"

fn increment(p *mut i64) {
	*p = *p + 1
}

fn readval(p *i64) i64 {
	return *p
}

fn showconstparam(x i64) {
	string.puti(readval(&x))
	string.puts("\n")
}

fn main() {
	var x i64
	x = 10

	increment(&x)
	string.puti(x)
	string.puts("\n")

	string.puti(readval(&x))
	string.puts("\n")

	showconstparam(42)
}
