package main

import "string.bo"

fn increment(p *mut i64) {
	*p = *p + 1
}

fn readval(p *i64) i64 {
	return *p
}

fn showconstparam(x i64) {
	puti(readval(&x))
	puts("\n")
}

fn main() {
	var x i64
	x = 10

	increment(&x)
	puti(x)
	puts("\n")

	puti(readval(&x))
	puts("\n")

	showconstparam(42)
}
