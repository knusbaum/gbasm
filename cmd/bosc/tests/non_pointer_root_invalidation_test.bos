package main

struct leaf { val i64 }
struct box {
	val i64
	child owned *?owned mut leaf
}

fn touch(p *mut i64) { *p = 1 }

fn main() {
	var b owned box = box{val: 1, child: nil}
	var c owned *?owned mut leaf = b.child
	var local i64 = 5
	var cond bool
	if (cond) {
		touch(&local)
	}
	if (c) { free(c) }
	dispose(b)
}
