package main

import "string"

struct big { a i64; b i64 }

fn add_to_a(var p big) big {
	p.a = p.a + 10
	return p
}

fn main() {
	var b big = big{a: 1, b: 2}
	var c big = add_to_a(b)
	string.puti(b.a); string.putc('\n')
	string.puti(b.b); string.putc('\n')
	string.puti(c.a); string.putc('\n')
	string.puti(c.b); string.putc('\n')
}
