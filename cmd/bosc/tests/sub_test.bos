package main

import "string.bo"

fn subby(x num, y num) num {
   return x - y
}

fn main() {
	puti(subby(20, 10))
	puts("\n")
	puti(subby(10, 20))
	puts("\n")

	var n num
	n = -1
	puti(n)
	puts("\n")

	n = abs(n)
	puti(n)
	puts("\n")
}

fn abs(n num) num {
	//if (n < 0) {
		n = -n
	//	return n
	//}
	return n
}
