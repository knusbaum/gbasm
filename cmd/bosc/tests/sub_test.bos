package main

import "string.bo"

fn subby(x i64, y i64) i64 {
   return x - y
}

fn main() {
	puti(subby(20, 10))
	puts("\n")
	puti(subby(10, 20))
	puts("\n")

	var n i64
	n = -1
	puti(n)
	puts("\n")

	n = abs(n)
	puti(n)
	puts("\n")
}

fn abs(var n i64) i64 {
	//if (n < 0) {
		n = -n
	//	return n
	//}
	return n
}
