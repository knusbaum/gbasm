package main

import "string"

fn subby(x i64, y i64) i64 {
   return x - y
}

fn main() {
	string.puti(subby(20, 10))
	string.puts("\n")
	string.puti(subby(10, 20))
	string.puts("\n")

	var n i64
	n = -1
	string.puti(n)
	string.puts("\n")

	n = abs(n)
	string.puti(n)
	string.puts("\n")
}

fn abs(var n i64) i64 {
	//if (n < 0) {
		n = -n
	//	return n
	//}
	return n
}
