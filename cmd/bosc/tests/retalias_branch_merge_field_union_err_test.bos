package main

// Hole B: two DIFFERENT borrowed params merged into one struct FIELD across
// an if must record BOTH (the field union) — not just the first/last branch.
// choose sets b.buf from param s in one branch and param t in the other, so
// choose's return aliases {0,1}. caller forwards a live param s in slot 0 but
// a LOCAL array's slice in slot 1, then returns choose(...). The pre-fix
// field merge dropped one param (recorded [[0]] or [[1]] by branch order), so
// the local in the unrecorded slot escaped uncaught — a use-after-free: the
// caller could free the dropped param while the return still borrows it. The
// fix records the union via a join origin, so the local in slot 1 surfaces
// and the escape is rejected regardless of branch order.
type B struct { buf byte[] }

fn choose(s byte[], t byte[], use_s bool) B {
	var b B
	if (use_s) {
		b.buf = s
	} else {
		b.buf = t
	}
	return b
}

fn caller(s byte[]) B {
	var loc byte[16]
	return choose(s, loc[:], (1 == 0))
}

fn main() {}
