package main

import "string"

fn main() {
   var x i64
   x = 1
   string.puti(x)
   string.puts("\n")

   x = x + 1
   string.puti(x)
   string.puts("\n")

   x = 1 + 2 - 3 + 4 - 5 + 6
   string.puti(x)
   string.puts("\n")

   // (4 * 2) + 3 - (4 / 2)
   // (8) + 3 - (2) = 9
   x = 4 * 2 + 3 - 4 / 2
   string.puti(x)
   string.puts("\n")

   // 4 * (2 + 3) - (4 / 2)
   // 4 * (5) - (2) = 18
   x = 4 * (2 + 3) - 4 / 2
   string.puti(x)
   string.puts("\n")
}