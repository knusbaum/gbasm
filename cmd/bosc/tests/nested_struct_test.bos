package main

import "string"

struct inner {
	a i64
	b i64
}

struct outer {
	x i64
	i inner
	y i64
}

fn main() {
	var o outer
	o.x = 1
	o.i.a = 2
	o.i.b = 3
	o.y = 4
	string.puti(o.x)
	string.puts("\n")
	string.puti(o.i.a)
	string.puts("\n")
	string.puti(o.i.b)
	string.puts("\n")
	string.puti(o.y)
	string.puts("\n")
}
