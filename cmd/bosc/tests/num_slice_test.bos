package main

import "string.bo"

fn sumslice(ns num[]) num {
	var i num
	var s num
	s = 0
	for (i = 0; i < lenn(ns); i = i + 1) {
		s = s + ns[i]
	}
	return s
}

fn main() {
	var arr num[5]
	arr[0] = 10
	arr[1] = 20
	arr[2] = 30
	arr[3] = 40
	arr[4] = 50

	var ns num[]
	ns = arr[:]
	puti(lenn(ns))
	puts("\n")
	puti(ns[2])
	puts("\n")
	puti(sumslice(ns))
	puts("\n")

	ns = arr[1:4]
	puti(lenn(ns))
	puts("\n")
	puti(sumslice(ns))
	puts("\n")
}
