package main
import "fmt"
import "io"

// Layer 4: a user type implementing Formatter renders via %v dispatch. The
// Formatter constructs its rendering on its own stack (here via a Builder)
// and writes it to the supplied writer.
type point struct { x i64, y i64 } {
	format(p *point, w io.writer) error {
		var buf byte[64]
		var b fmt.Builder := fmt.Builder{buf: buf[:], pos: 0, err_: io.io_err.OK}
		b.str("(")
		b.int(p.x)
		b.str(", ")
		b.int(p.y)
		b.str(")")
		if (b.error() != io.io_err.OK) { return b.error() }
		bs byte[] := b.bytes()
		_, err := w.write(bs)
		return err
	}
}

fn main() i64 {
	var pt point := point{x: 3, y: 4}
	fmt.print("at %v\n", &pt)
	return 0
}
