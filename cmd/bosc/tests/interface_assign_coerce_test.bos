package main

import "string"

type dog i64 {
	speak(d *dog) byte[] {
		return "woof"
	}
}

type cat i64 {
	speak(c *cat) byte[] {
		return "meow"
	}
}

interface Animal {
	speak(a *self) byte[]
}

fn main() i64 {
	var d dog = 0
	var c cat = 0
	var a Animal = &d

	string.puts(a.speak())
	string.puts("\n")

	a = &c

	string.puts(a.speak())
	string.puts("\n")

	return 0
}
