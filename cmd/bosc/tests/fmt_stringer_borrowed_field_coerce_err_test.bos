package main
import "fmt"
import "io"

// A type whose `string()` method returns a borrow of its receiver field
// (the canonical stringer-renders-itself pattern) may NOT be coerced to
// any interface — including the `any` that fmt.print packs its varargs
// into. Inferred return-parameter aliasing closes the runtime-itab
// laundering path (fmt's render_v asserts `a.(stringer)`); the coercion
// is rejected at the static entry point (here, the implicit coercion of
// &w into the `any` vararg). See PROPOSAL_return_alias_inference.md
// (Interface-method dispatch, option (a)).
type word struct { s byte[] } {
	string(w *word) byte[] { return w.s }
}

fn main() i64 {
	var s byte[] = "hello-stringer"
	var w word = word{s: s}
	fmt.print("v=%v\n", &w)
	return 0
}
