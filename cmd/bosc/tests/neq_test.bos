package main

import "string"

fn main() {
	var x i64
	x = 5

	if (x != 5) {
		string.puts("wrong\n")
	} else {
		string.puts("equal\n")
	}

	if (x != 4) {
		string.puts("not equal\n")
	} else {
		string.puts("wrong\n")
	}

	if (x <= 5) {
		string.puts("le 5\n")
	} else {
		string.puts("wrong\n")
	}

	if (x <= 6) {
		string.puts("le 6\n")
	} else {
		string.puts("wrong\n")
	}

	if (x <= 4) {
		string.puts("wrong\n")
	} else {
		string.puts("not le 4\n")
	}
}
