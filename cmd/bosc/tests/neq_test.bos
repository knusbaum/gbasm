package main

import "string.bo"

fn main() {
	var x num
	x = 5

	if (x != 5) {
		puts("wrong\n")
	} else {
		puts("equal\n")
	}

	if (x != 4) {
		puts("not equal\n")
	} else {
		puts("wrong\n")
	}

	if (x <= 5) {
		puts("le 5\n")
	} else {
		puts("wrong\n")
	}

	if (x <= 6) {
		puts("le 6\n")
	} else {
		puts("wrong\n")
	}

	if (x <= 4) {
		puts("wrong\n")
	} else {
		puts("not le 4\n")
	}
}
