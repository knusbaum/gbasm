package main
import "string"

interface counter {
	count(self ic) i64
}

type ic i64 {
	count(self ic) i64 {
		return 1
	}
}

fn main() i64 {
	n ic := 4
	s counter := n          // value-shape interface
	a any := s              // widen to any (infallible)
	string.puts("ok")
	string.putc(10)
	v ic, ok2 bool := a.(ic)   // concrete-target assert: 2-value
	if (ok2) {
		string.puts("kept")
	} else {
		string.puts("lost")
	}
	string.putc(10)
	return 0
}
