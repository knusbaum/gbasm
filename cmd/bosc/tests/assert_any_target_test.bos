package main
import "string"

interface counter {
	count(self ic) i64
}

type ic i64 {
	count(self ic) i64 {
		return 1
	}
}

fn main() i64 {
	var n ic = 4
	var s counter = n          // value-shape interface
	var a any, var ok bool = s.(any)
	if (ok) {
		string.puts("ok")
	} else {
		string.puts("no")
	}
	string.putc(10)
	var v ic, var ok2 bool = a.(ic)
	if (ok2) {
		string.puts("kept")
	} else {
		string.puts("lost")
	}
	string.putc(10)
	return 0
}
