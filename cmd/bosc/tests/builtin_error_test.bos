package main

import "string"

// myError implements the builtin error interface.
type myError i64 {
    message(_ *myError) byte[] {
        return "something went wrong"
    }
    destroy(e owned *myError) {
        dispose(e)
    }
}

fn showError(err error) {
    string.puts(err.message())
    string.puts("\n")
}

fn main(_ byte[][]) {
    var e myError := 0
    showError(&e)
}
