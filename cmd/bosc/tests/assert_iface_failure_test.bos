package main
import "string"

// greeter has a greet method; barer does not.
type greeter i64 {
	greet(_ *self) byte[] {
		return "hi"
	}
}
type barer i64 {
	other(_ *self) i64 {
		return 0
	}
}

interface speaker {
	greet(s *self) byte[]
}

fn main() i64 {
	var b barer := 3
	a any := &b
	s ?speaker := a.(speaker)
	if (s != nil) {
		string.puts("yes")
	} else {
		string.puts("no")
	}
	string.putc(10)
	return 0
}
