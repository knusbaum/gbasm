package main

import "string.bo"

fn main() {
	var i i64
	for (i = 0; i < 10; i = i + 1) {
		puti(i)
		puts("\n")
	}

	for (i = 10; i >= 0; i = i - 1) {
		puti(i)
		puts("\n")
	}

	// nesting
	for (i = 0; i < 5; i = i + 1) {
		var j i64
		for (j = 0; j < 2; j = j + 1) {
			puti(i)
			puti(j)
			puts("\n")
		}
	}

	// continue
	for (i = 0; i < 10; i = i + 1) {
		if (i == 5) {
			continue
		}
		puti(i)
	}
	puts("\n")
	// break
	for (i = 0; i < 10; i = i+1) {
		if (i == 5) {
			break
		}
		puti(i)
	}
	puts("\n")
}
