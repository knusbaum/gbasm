package main

import "string"

// Positive test for slice-by-value return. The slice's data root is a
// file-scope global (process-lifetime storage), so no borrow-escape
// question arises — the only thing under test is the return ABI.
//
// A slice header is 16 bytes (data ptr, length). Under SysV AMD64 a
// 16-byte aggregate return rides in rax+rdx; the function emits the
// header into those registers and the caller reassembles it.

var buf byte[8]

fn get_view() byte[] {
	return buf[:5]
}

fn main() {
	buf[0] = 'A'
	buf[1] = 'B'
	buf[2] = 'C'
	buf[3] = 'D'
	buf[4] = 'E'
	buf[5] = 'X'
	buf[6] = 'Y'
	buf[7] = 'Z'
	bs byte[] := get_view()
	string.puts(bs)
	string.puts("\n")
}
