package main
import "fmt"
import "string"

// Layer 1: itoa renders signed decimals into a caller buffer and returns the
// rendered bytes as a sub-slice of that buffer (a borrow of the out param,
// now legal via return-alias inference). Covers zero, positive, negative,
// the min-i64 edge, the truncation contract, and n_digits.
fn show(n i64) i64 {
	var buf byte[32]
	s byte[] := fmt.itoa(buf[:], n)
	string.puts(s)
	string.puts(" (")
	string.puti(fmt.n_digits(n))
	string.puts(")\n")
	return 0
}

fn main() i64 {
	show(0)
	show(7)
	show(0 - 7)
	show(12345)
	show(0 - 9223372036854775808)   // min i64
	// Truncation: a 3-byte buffer holds only the first 3 chars of "12345";
	// len of the returned slice is the kept count.
	var small byte[3]
	s1 byte[] := fmt.itoa(small[:], 12345)
	string.puts(s1)
	string.puts(" trunc=")
	string.puti(len(s1))
	string.putc(10)
	// Negative truncation: the leading '-' counts toward the kept prefix, so
	// "-12345" into 3 bytes keeps "-12" (len 3) and into 1 byte keeps "-"
	// (len 1). Exercises write_decimal_trunc on the negative path.
	var negsmall byte[3]
	s2 byte[] := fmt.itoa(negsmall[:], 0 - 12345)
	string.puts(s2)
	string.puts(" trunc=")
	string.puti(len(s2))
	string.putc(10)
	var neg1 byte[1]
	s3 byte[] := fmt.itoa(neg1[:], 0 - 7)
	string.puts(s3)
	string.puts(" trunc=")
	string.puti(len(s3))
	string.putc(10)
	return 0
}
