package main

import "string"

type pair struct {
	x i64
	y i64
}

fn main() {
	n owned *mut i64 := alloc(i64)
	*n = 123
	string.puti(*n)
	string.puts("\n")
	free(n)

	p owned *mut pair := alloc(pair)
	p.x = 7
	p.y = 8
	string.puti(p.x)
	string.puts("\n")
	string.puti(p.y)
	string.puts("\n")
	free(p)
}
