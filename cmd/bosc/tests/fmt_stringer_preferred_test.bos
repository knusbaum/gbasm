package main
import "fmt"
import "io"

// A type implementing BOTH stringer and Formatter renders via stringer under
// %v — stringer wins the preference order in render_v. This is the ONLY test
// pinning that precedence. The stringer returns a static .rodata slice (a
// string literal), not a borrow of the receiver, so the type still coerces to
// `any` (the vararg shape); a borrowed-self stringer would be rejected at the
// coercion. If the Formatter were preferred, the output would read
// "FORMATTER" instead.
type tag struct { label i64 } {
	string(_ *tag) byte[] { return "STRINGER" }
	format(_ *tag, w io.writer) error {
		_, err := w.write("FORMATTER")
		return err
	}
}

fn main() i64 {
	var t tag := tag{label: 1}
	fmt.print("got %v\n", &t)
	return 0
}
