package main

// Asserting *from* a nullable interface dereferences its vtable, so it too
// must be narrowed first — `k.(U)` on an un-narrowed `?K` is rejected.
interface K { f(s *self) byte[] }
interface U { f(s *self) byte[] }
type T i64 { f(t *T) byte[] { return "x" } }

fn main() i64 {
	var t T = 3
	var a any = &t
	var k ?K = a.(K)
	var u ?U = k.(U)
	return 0
}
