package main

import "string"

fn add(a i64, b i64) i64 {
	return a + b
}

fn main() i64 {
	// infer i64 from integer literal
	var x = 42
	// infer i64 from function return
	var y = add(10, 20)
	// infer pointer type
	var z = &x
	// infer from expression
	var w = x + y

	string.puti(x)
	string.puts("\n")
	string.puti(y)
	string.puts("\n")
	string.puti(*z)
	string.puts("\n")
	string.puti(w)
	string.puts("\n")
	return 0
}
