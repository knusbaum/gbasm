package main

import "string"

type poly struct {
	x i64
	y i64
	bs byte[]
}


fn dosth(bs byte[]) poly {
	var p poly

	p = poly{
		x: 1,
		y: 2
	}
	p.bs = bs[:10]

	return p
}


fn main() i64 {
	var arr byte[100]

	var p poly
	p = dosth(arr[:])

	string.puts("X: ")
	string.puti(p.x)
	string.puts("\nY: ")
	string.puti(p.y)
	string.puts("\nbs: ")
	string.puti(len(p.bs))
	string.puts("\n")
}
