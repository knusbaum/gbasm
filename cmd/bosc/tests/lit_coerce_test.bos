package main

import "string.bo"

// Tests that a literal is accepted at an i8 call site without error.
// (Using the parameter inside the function body is a separate issue.)
fn accepti8(x i8) i64 {
	return 0
}

fn main() {
	// literal coerced to i8 at call site; 50 fits in i8
	var r i64
	r = accepti8(50)
	if (r == 0) { puts("func arg ok\n") } else { puts("func arg fail\n") }

	// negative literal expression assigned directly to i8
	var y i8
	y = 0 - 5
	if (y < 0) { puts("neg lit ok\n") } else { puts("neg lit fail\n") }

	// literal expression folded and coerced to i16
	var z i16
	z = 100 + 200
	if (z == 300) { puts("lit fold ok\n") } else { puts("lit fold fail\n") }
}
