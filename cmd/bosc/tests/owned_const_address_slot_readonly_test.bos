package main

type thing struct {
	val i64
}

fn main() {
	// `&a` of an owned binding yields a read-only `**mut thing` view, not
	// `**owned mut thing` — asserted by this declaration compiling at all.
	// The binding exists for that type assertion; its value is irrelevant.
	a owned *owned mut thing := new(thing{val: 1})
	slot **mut thing := &a
	_ := slot
	free(a)
}
