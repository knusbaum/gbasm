package main
import "string"

// Implicit interfaceâ†’interface widening: `var a any = v` widens a viewer to
// the empty interface (zero methods âŠ† everything) without an explicit
// assertion. The widened `any` still carries W's concrete typedesc, so a
// later a.(Byter) (non-declaring) is blocked while a.(viewer) succeeds.
interface viewer { bytes(self *self) byte[] from(self) }
interface Byter { bytes(self *self) byte[] }
type W struct { buf byte[] } {
	bytes(w *W) byte[] { return w.buf }
}

fn main() i64 {
	var w W := W{buf: "hi"}
	v viewer := &w
	a any := v
	k ?Byter := a.(Byter)
	if (k != nil) {
		string.puts("LAUNDERED")
	} else {
		string.puts("blocked")
	}
	string.putc(10)
	v2 ?viewer := a.(viewer)
	if (v2 != nil) {
		r byte[] := v2.bytes()
		string.puts(r)
	} else {
		string.puts("rejected")
	}
	string.putc(10)
	return 0
}
