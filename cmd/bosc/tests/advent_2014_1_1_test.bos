package main

import "string.bo"

struct state {
	one i64
	two i64
	remaining byte[]
	complete i64
}

fn skip(var bs byte[]) byte[] {
	var i i64
	for (i = 0; i < lenb(bs); i = i+1) {
		if ((bs[i] >= '0') && (bs[i] <= '9')) {
			bs = bs[i:]
			break
		}
	}
	return bs
}

fn readRow(var bs byte[]) state {
	var onea byte[10]
	var twoa byte[10]

	var onebs byte[]
	onebs = onea[:]
	var twobs byte[]
	twobs = twoa[:]

	// scan forward to the next number
	bs = skip(bs)
	
	var i i64
	var bsi i64
	bsi = 0
	for (i = 0; i < lenb(bs); i=i+1) {
		if (bs[i] < '0' || bs[i] > '9') {
			// we're out of the number
			// slice the slice
			bs = bs[i:]
			break
		}
		onebs[bsi] = bs[i]
		bsi = bsi + 1
	}
	onebs = onebs[:bsi]

	// scan forward to the next number
	bs = skip(bs)

	bsi = 0
	for (i = 0; i < lenb(bs); i=i+1) {
		if (bs[i] < '0' || bs[i] > '9') {
			// we're out of the number
			// slice the slice
			bs = bs[i:]
			break
		}
		twobs[bsi] = bs[i]
		bsi = bsi + 1
	}
	twobs = twobs[:bsi]

	// look for newline to ensure we read the full line.
	var found i64
	found = 0
	for (i = 0; i < lenb(bs); i = i+1) {
	 	if(bs[i] == '\n') {
	 		found = 1
	 		bs = bs[i:]
			break
	 	}
	}
	
	var pnum nret
	var onei i64
	var twoi i64
	pnum = atoi(onebs)
	if (pnum.err) {
		puts("failed to atoi.\n")
		exit(1)
	}
	onei = pnum.i

	pnum = atoi(twobs)
	if (pnum.err) {
		puts("failed to atoi.\n")
		exit(1)
	}
	twoi = pnum.i
	
	var st state
	st = state{
		one: onei,
		two: twoi,
		complete: found
	}
	st.remaining = bs
	return st
}

fn dumpbs(bs byte[]) {
	var i i64
	for (i = 0; i < lenb(bs); i = i + 1) {
		putc(bs[i])
	}
	puts("\n")
}

fn dumpns(ns i64[]) {
	var i i64
	for (i = 0; i < lenn(ns); i = i + 1) {
		puti(ns[i])
		putc(' ')
	}
	puts("\n")
}

fn qsort(ns i64[]) {
	if (lenn(ns) <= 0) {
		return 0
	}
	var pi i64
	pi = partition(ns)
	if (pi > 0) {
		var t i64
		t = pi
		qsort(ns[:t])
	}
	if (pi < lenn(ns)-1) {
		var t2 i64
		t2 = pi + 1
		qsort(ns[t2:])
	}
}

fn partition(ns i64[]) i64 {
	var pivot i64
	var i i64
	pivot = ns[lenn(ns) - 1]	
	i = 0

	var j i64
	for (j = 0; j < lenn(ns) - 1; j = j + 1) {
		if (ns[j] <= pivot) {
			var tmp i64
			tmp = ns[i]
			ns[i] = ns[j]
			ns[j] = tmp
			i = i + 1
		}
	}
	var tmp i64
	tmp = ns[i]
	ns[i] = ns[lenn(ns) - 1]
	ns[lenn(ns)- 1] = tmp
	return i
}


fn main() i64 {
	var fd i64
	fd = open("tests/advent_2014_1.txt", 0, 0)
	if (fd < 0) {
		puts("Failed to open io_test.bos: ")
		puti(fd)
		puts("\n")
		return 1
	}
	var left i64[1000]
	var right i64[1000]
	var row i64
	row = 0
	
	var buf byte[28]
	var bs byte[]
	bs = buf[:]
	var remaining i64
	remaining = 0
	for(0; 1 == 1 ; 0) {
		var n i64
		n = read(fd, bs)
		bs = buf[:n+remaining]
		if(n <= 0) {
			puts("Completed reading.\n")
			break
		}

		var s state
		for(0; lenb(bs) > 4; 0) {
			s = readRow(bs)
			if ( s.complete == 0 ) {
				s.remaining = bs
				break
			}
			left[row] = s.one
			right[row] = s.two
			row = row + 1
			bs = s.remaining		
		}
		
		// copy out the remaining buffer for the next round.
		var i i64
		bs = s.remaining
		for (i = 0; i < lenb(bs); i = i + 1) {
			buf[i] = bs[i]
		}
		bs = buf[i:]
		remaining = lenb(s.remaining)
	}

	var i i64
	qsort(left[:row])
	qsort(right[:row])
	var diffi i64
	diffi = 0
	for(i = 0; i < row; i = i + 1) {
		var ti i64
		ti = left[i] - right[i]
		if (ti < 0 ) {
			ti = -ti
		}
		var tmpi i64
		diffi = diffi + ti
	}
	puts("Part 1 Result: ")
	puti(diffi)
	puts("\n")

	// Part 2 (similarity)
	var sim i64
	sim = similarity(left[:row], right[:row])

	puts("Part 2 Result: ")
	puti(sim)
	puts("\n")
}

fn similarity(left i64[], right i64[]) i64 {
	var i i64
	var j i64
	var sim i64
	sim = 0
	for (i = 0; i < lenn(left); i = i + 1) {
		var ln i64
		ln = left[i]
		var instances i64
		instances = 0
		for (j = 0; j < lenn(right); j = j + 1) {
			var rn i64
			rn = right[j]
			if(ln == rn) {
				instances = instances + 1
			}
			// we can skip more if rn > ln since the lists are sorted.
			if (rn > ln) {
				break
			}
		}
		sim = sim + (ln * instances)
	}
	return sim
}

struct nret {
	i i64
	err bool
}

fn atoi(s byte[]) nret {
	var true bool
	var false bool
	true = (0 == 0)
	false = (1 == 0)
	
	var l i64
	l = lenb(s)
	var i i64
	var r i64
	r = 0
	for (i = 0; i < l; i = i + 1) {
		r = r * 10
		var b byte
		b = s[i]
		if (b == '1') {
			r = r + 1
		} else if (b == '2') {
			r = r + 2
		} else if (b == '3') {
			r = r + 3
		} else if (b == '4') {
			r = r + 4
		} else if (b == '5') {
			r = r + 5
		} else if (b == '6') {
			r = r + 6
		} else if (b == '7') {
			r = r + 7
		} else if (b == '8') {
			r = r + 8
		} else if (b == '9') {
			r = r + 9
		} else if (b == '0') {
			
		} else {
			return nret{i: 0, err: true }
		}
	}
	return nret{i:r, err: false}
}
