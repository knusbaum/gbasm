package main

import "string"

// Positive twin: the nested literal-from-call borrowing a PARAM records
// transitively (outer2 infers [[0]]) and runs.
type B struct { buf byte[] }
type Outer struct { inner B }
fn mk(s byte[]) B { return B{buf: s} }
fn outer2(p byte[]) Outer { return Outer{inner: mk(p)} }
fn main() i64 {
	data byte[] := "ok"
	o Outer := outer2(data)
	string.puts(o.inner.buf)
	string.puts("\n")
	return 0
}
