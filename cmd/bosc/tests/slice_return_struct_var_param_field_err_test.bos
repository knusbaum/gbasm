package main

// Borrowed slice parameter routed through a local struct var, then the
// struct is returned by value. The slice field carries the parameter's
// lifetime constraint; returning the struct copy would carry that view
// past the call's frame.

type B struct {
	buf byte[]
}

fn wrap(s byte[]) B {
	var b B
	b.buf = s
	return b
}

fn main() {}
