package main
import "fmt"
import "io"

// Layer 5: %v dispatches to Formatter when stringer is absent.
type span struct { lo i64, hi i64 } {
	format(s *span, w io.writer) error {
		var buf byte[64]
		var b fmt.Builder = fmt.Builder{buf: buf[:], pos: 0, err_: io.io_err.OK}
		b.str("[")
		b.int(s.lo)
		b.str("..")
		b.int(s.hi)
		b.str("]")
		var bs byte[] = b.bytes()
		const _, var err = w.write(bs)
		return err
	}
}

fn main() i64 {
	var s span = span{lo: 2, hi: 9}
	fmt.print("range %v done\n", &s)
	return 0
}
