package main

import "string"

type box struct {
	x owned i64
	y i64
}

fn make_box() owned box {
	var b box
	b.x = 33
	b.y = 44
	return owned(b)
}

fn borrow_box(b box) {
	string.puti(b.x)
	string.puts("\n")
	string.puti(b.y)
	string.puts("\n")
}

fn main() {
	b owned box := make_box()
	borrow_box(b)
	dispose(b)
}
