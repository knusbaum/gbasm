package main

import "string"

type box struct { val i64 }

// id returns its borrowed pointer parameter unchanged. This exercises the
// direct-pointer-return site (checkBorrowedPointerDoesNotEscape), which a
// slice passthrough never reaches. ReturnAliases=[[0]].
fn id(p *box) *box {
	return p
}

fn main() i64 {
	var b box := box{val: 42}
	p *box := id(&b)
	string.puti(p.val)
	string.puts("\n")
	return 0
}
