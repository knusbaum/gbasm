package main

// Storing a borrowed slice into a local struct field and re-slicing it
// must preserve the parameter's borrow. The re-slice reads the field's
// slice header, whose data pointer is the borrowed source — same shape
// as returning `s` directly, just routed through `b.buf` first.

type B struct {
	buf byte[]
}

fn bad(s byte[]) byte[] {
	var b B
	b.buf = s
	return b.buf[:]
}

fn main() {}
