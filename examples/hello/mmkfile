## A minimal Boson project. Builds an executable from src/ and links
## against whatever packages the source imports.
##
## Build with:
##   BOSON_HOME=../.. mmk

# Defaults: use binaries from the gbasm repo build outputs.
BOSON_HOME=${BOSON_HOME:-../..}
BOSC=${BOSC:-$BOSON_HOME/bosc}
BAS=${BAS:-$BOSON_HOME/bas}
BLD=${BLD:-$BOSON_HOME/bld}
BDOC=${BDOC:-$BOSON_HOME/bdoc}

include $BOSON_HOME/boson.mmk

all : hello

bos_exe hello source=src :

## run the cat example
run : hello {
    ./target/hello
}
