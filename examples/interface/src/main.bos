package main

import "string"

interface helloer {
	hello(h *self)
}

type thingy i64 {
	hello(t *thingy) {
		string.puts("hello, thingy: ")
		string.puti(i64(*t))
		string.puts("\n")
	}
}

fn do_helloer(h helloer) {
	h.hello()
}

fn main(args byte[][]) {
	var t thingy = 100
	do_helloer(&t)
	t = 20
	do_helloer(&t)
}
