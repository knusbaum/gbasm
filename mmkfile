BOSON_HOME=${BOSON_HOME:-.}
BOSC=${BOSC:-./bosc}
BAS=${BAS:-./bas}
BLD=${BLD:-./bld}
BDOC=${BDOC:-./bdoc}
BOSONPATH=${BOSONPATH:-$BOSON_HOME/runtime:.}
PLAYGROUND_BUNDLE=${PLAYGROUND_BUNDLE:-target/playground}
PLAYGROUND_BUNDLE_PREFIX=${PLAYGROUND_BUNDLE_PREFIX:-$(pwd)/$PLAYGROUND_BUNDLE}

all: bld bas bosc bdoc

# Toolchain binaries: untyped (phony) so mmk always invokes `go build`,
# which is fast under Go's own build cache and is the only layer that
# tracks .go source changes accurately. The previous `file <name> { go
# build ... }` form pinned freshness to the binary's mtime with no deps,
# so once the binary existed mmk skipped the body and edits to .go files
# never propagated.

## Build the Boson linker
bld  { go build ./cmd/bld }
## Build the Boson assembler
bas  { go build ./cmd/bas }
## Build the Boson compiler
bosc { go build ./cmd/bosc }
## Build the Boson documentation server
bdoc { go build ./cmd/bdoc }
## Build the Boson playground server
bplayd { go build ./cmd/bplayd }
## Build the Boson playground sandbox runner
bplay-runner { go build ./cmd/bplay-runner }
## Build the Boson tour server
btourd { go build ./cmd/btourd }

[clean bld]  { rm -f bld }
[clean bas]  { rm -f bas }
[clean bosc] { rm -f bosc }
[clean bdoc] { rm -f bdoc }
[clean bplayd] { rm -f bplayd }
[clean bplay-runner] { rm -f bplay-runner }
[clean btourd] { rm -f btourd }

[clean all] :+ [clean cmd/bas] [clean cmd/bosc]

include ./boson.mmk

playground-runtime : target/builtin.bo target/io.bo target/fmt.bo target/_io_sys.bo target/_heap.bo target/_init.bo target/_iface.bo {
    set -e
    mkdir -p "$PLAYGROUND_BUNDLE/objects"
    cp target/builtin.bo "$PLAYGROUND_BUNDLE/objects/builtin.bo"
    cp target/io.bo "$PLAYGROUND_BUNDLE/objects/io.bo"
    cp target/fmt.bo "$PLAYGROUND_BUNDLE/objects/fmt.bo"
    cp target/_io_sys.bo "$PLAYGROUND_BUNDLE/objects/_io_sys.bo"
    cp target/_heap.bo "$PLAYGROUND_BUNDLE/objects/_heap.bo"
    cp target/_init.bo "$PLAYGROUND_BUNDLE/objects/_init.bo"
    cp target/_iface.bo "$PLAYGROUND_BUNDLE/objects/_iface.bo"
    cat > "$PLAYGROUND_BUNDLE/importcfg" <<EOF
builtin=$PLAYGROUND_BUNDLE_PREFIX/objects/builtin.bo
io=$PLAYGROUND_BUNDLE_PREFIX/objects/io.bo
fmt=$PLAYGROUND_BUNDLE_PREFIX/objects/fmt.bo
EOF
}

playground: bplayd bplay-runner playground-runtime

## Build the tour server and its run sandbox. The tour reuses the
## playground runtime bundle (identical runtime objects); there is no
## separate tour bundle.
tour: btourd bplay-runner playground-runtime

test: go_test cmd/bas/test cmd/bosc/test

go_test {
    go test -count 1 ./...
}

subproject cmd/bas
subproject cmd/bosc

subproject examples/buggy
subproject examples/cat
subproject examples/hello


sloc {
    echo "Source Lines of Code:"
    find . -iname '*.go' -or -iname '*.sh' -or -iname '*.bos' -or -iname '*.bs' | xargs -n 1 cat | grep -v '^$$' | sed 's|^\s*||g' | grep -v '^//' | wc -l
}

loc {
    echo "Lines of Code:"
    find . -iname '*.go' -or -iname '*.sh' -or -iname '*.bos' -or -iname '*.bs' | xargs -n 1 cat | wc -l
}
