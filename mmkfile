all: bld bas bosc bdoc

[clean all] :+ [clean cmd/bas] [clean cmd/bosc]

file bld {
    go build ./cmd/bld
}  

file bas {
    go build ./cmd/bas
}

file bosc {
    go build ./cmd/bosc
}

file bdoc {
    go build ./cmd/bdoc
}

# docs builds bdoc and runs it in the foreground. `exec` replaces the
# shell with the bdoc process so Ctrl-C in the launching terminal
# reaches bdoc directly — without exec, mmk's intermediate shell
# eats SIGINT, returns control to the user's shell, and leaves bdoc
# orphaned in the background still holding the port. bdoc itself has
# a PDEATHSIG fallback for the case where some other caller spawns
# it without exec; this target makes the common path correct.
docs: bdoc {
    exec ./bdoc -path ./runtime
}

test: go_test cmd/bas/test cmd/bosc/test

go_test {
    go test -count 1 ./...
}

subproject cmd/bas
subproject cmd/bosc

sloc {
    echo "Source Lines of Code:"
    find . -iname '*.go' -or -iname '*.sh' -or -iname '*.bos' -or -iname '*.bs' | xargs -n 1 cat | grep -v '^$$' | sed 's|^\s*||g' | grep -v '^//' | wc -l
}

loc {
    echo "Lines of Code:"
    find . -iname '*.go' -or -iname '*.sh' -or -iname '*.bos' -or -iname '*.bs' | xargs -n 1 cat | wc -l
}
