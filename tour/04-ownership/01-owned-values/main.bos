package main

import "fmt"

// commit consumes its argument: `owned` in the parameter type moves it.
fn commit(id owned i64) {
	fmt.print("committed ticket %d\n", id)
	dispose(id)
}

fn main() {
	var ticket owned i64 := 1001
	commit(ticket) // ticket's obligation moves into commit
	fmt.print("done\n")
}
