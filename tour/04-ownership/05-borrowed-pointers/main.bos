package main

import "fmt"

// inspect borrows: no `owned` in the parameter, so the obligation stays home.
fn inspect(p *i64) {
	fmt.print("value is %d\n", *p)
}

fn main() {
	var conn owned i64 = 55
	inspect(&conn) // borrow — conn is still owned afterward
	dispose(conn)  // the caller still owns conn; satisfy the obligation
	fmt.print("closed\n")
}
