package main

import "fmt"

interface named {
	name(self *self) byte[]
}

type dog i64 {
	name(d *dog) byte[] { return "Rex" }
}

fn main() {
	var d dog := 1
	a any := &d
	n ?named := a.(named) // fallible assertion -> nullable interface
	if (n != nil) {
		var nm byte[] := n.name()
		fmt.print("name: %s\n", &nm)
	} else {
		fmt.print("not named\n")
	}
}
